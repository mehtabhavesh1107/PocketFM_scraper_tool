{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "framework": "vite",
      "routePrefix": "/"
    },
    "backend": {
      "entrypoint": "backend/app.py",
      "framework": "fastapi",
      "routePrefix": "/api",
      "memory": 2048,
      "maxDuration": 900
    }
  }
}
