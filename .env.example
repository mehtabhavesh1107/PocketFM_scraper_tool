# Local dev and the full-stack Docker/Render app use the same-origin API path.
# Override only if the Vite UI is hosted separately from the FastAPI backend.
VITE_API_BASE_URL=/api

# Recommended for persistent cloud data on Render or any cloud backend.
# Without this, the app falls back to local SQLite storage.
# COMMISSIONING_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
